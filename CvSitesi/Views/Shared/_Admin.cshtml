        <a href="/Admin/Egitim" class="w3-bar-item w3-button">Eğitim</a>
        <a href="/Admin/Sertifika" class="w3-bar-item w3-button">Sertifikalar</a>
        <a href="/Admin/Iletisim" class="w3-bar-item w3-button">İletişim</a>
        <a href="/Admin/Admin" class="w3-bar-item w3-button">Admin</a>

        <a target="_blank" href="/AnaSayfa" class="w3-bar-item w3-button">Siteye Git</a>
        <a href="/Admin/CıkısYap/" class="w3-bar-item w3-button">Çıkış Yap</a>
    </div>


    <!-- Page Content -->
    <div style="margin-left:15%">

        @RenderBody()

    </div>


    <!-- FA | JS -->
    <script src="/cvfrontend/admin/fontawesome/66637520bd.js" crossorigin="anonymous"></script>
    <script src="~/cvfrontend/admin/js/bootstrap.bundle.js"></script>


</body>
</html>




