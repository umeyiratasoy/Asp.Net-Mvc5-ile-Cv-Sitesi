
@{
    Layout = null;
}
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8">
    <meta name="viewport" content="width=device-width, initial-scale=1">
    <!-- BS -->
    <link rel="stylesheet" href="~/cvfrontend/admin/css/bootstrap.min.css">
    <meta name="viewport" content="width=device-width, initial-scale=1">
    <link rel="stylesheet" href="https://www.w3schools.com/w3css/4/w3.css">
    <script src="https://kit.fontawesome.com/66637520bd.js" crossorigin="anonymous"></script>
    <title>CV - Admin</title>
</head>
<body class="bg-light">

    <div class="bg-dark">
        <div class=" mt-auto py-3" align="center">
            <i class="fa-solid fa-fire-flame-curved text-light">
                <h6 class="text-light"> 2022 | Ümeyİr ATASOY</h6>
            </i>
        </div>
    </div>



    <!-- Sidebar -->
    <div class="w3-sidebar w3-light-grey w3-bar-block" style="width:15%">
        <h3 class="w3-bar-item">Menu</h3>
        <a href="/Admin/GenelAyarlar" class="w3-bar-item w3-button">Biyografi</a>
